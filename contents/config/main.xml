<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0 http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
    <kcfgfile name=""/>

    <group name="General">
        <entry name="displaymode" type="String">
            <default>GIF</default>
        </entry>
        <entry name="gifspeed" type="Double">
            <default>1</default>
        </entry>
        <entry name="glbspeed" type="Double">
            <default>2</default>
        </entry>
        <entry name="allowcameradrag" type="Bool">
            <default>true</default>
        </entry>
        <entry name="camposx" type="Double">
            <default>10</default>
        </entry>
        <entry name="camposy" type="Double">
            <default>8</default>
        </entry>
        <entry name="camposz" type="Double">
            <default>5</default>
        </entry>
        <entry name="camrotx" type="Double">
            <default>-20</default>
        </entry>
        <entry name="camroty" type="Double">
            <default>0</default>
        </entry>
        <entry name="camzoom" type="Double">
            <default>33</default>
        </entry>
        <entry name="mirror" type="Bool">
            <default>false</default>
        </entry>
        <entry name="hq" type="Bool">
            <default>true</default>
        </entry>
        <entry name="playthemesong" type="String">
            <default>On Double Click</default>
        </entry>
        <entry name="themesongloops" type="Int">
            <default>1</default>
        </entry>
        <entry name="gifpath" type="Path">
            <default>assets/maxwell-spinning.gif</default>
        </entry>
        <entry name="glbpath" type="Path">
            <default>assets/maxwell-spinning.glb</default>
        </entry>
        <entry name="themepath" type="Path">
            <default>assets/stockmarket.wav</default>
        </entry>
    </group>
</kcfg>
